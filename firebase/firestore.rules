rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read-only park content — managed by admins via the console.
    match /rides/{rideId} {
      allow read: if true;
      allow write: if false;
    }
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if false;
    }
    match /events_offers/{itemId} {
      allow read: if true;
      allow write: if false;
    }
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if false;
    }
    match /map_zones/{zoneId} {
      allow read: if true;
      allow write: if false;
    }

    // Each user can only read/write their own profile + tickets.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /tickets/{ticketId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
