rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for park content images (rides, restaurants, gallery, events)
    match /content/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Users can only upload/replace their own profile photo
    match /profile_photos/{userId}.jpg {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
